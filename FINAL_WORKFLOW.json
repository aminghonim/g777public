            "position": [
                -1000,
                0
            ],
            "id": "webhook-trigger",
            "name": "Webhook (WhatsApp)"
        },
        {
            "parameters": {
                "conditions": {
                    "boolean": [
                        {
                            "value1": "={{ $json.body.data.key.fromMe }}",
                            "value2": false
                        }
                    ]
                }
            },
            "type": "n8n-nodes-base.if",
            "typeVersion": 2,
            "position": [
                -780,
                0
            ],
            "id": "filter-from-me",
            "name": "Filter: Not From Me"
        },
        {
            "parameters": {
                "method": "POST",
