            "name": "AI Agent"
        },
        {
            "parameters": {
                "method": "POST",
                "url": "=http://localhost:3000/message/sendText/G777",
                "sendHeaders": true,
                "headerParameters": {
                    "parameters": [
                        {
                            "name": "apikey",
                            "value": "os.getenv('EVOLUTION_API_KEY', 'your_api_key_here')"
                        }
                    ]
                },
                "sendBody": true,
                "bodyParameters": {
                    "parameters": [
                        {
                            "name": "number",
