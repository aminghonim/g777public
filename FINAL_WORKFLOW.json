            "type": "@n8n/n8n-nodes-langchain.googleGemini",
            "typeVersion": 1,
            "position": [
                -120,
                240
            ],
            "id": "gemini-chat-model",
            "name": "Google Gemini Chat Model",
            "credentials": {
                "googleGeminiApi": {
                    "id": "GOOGLE_GEMINI_CRED_ID",
                    "name": "Google Gemini Api account"
                }
            }
        },
        {
            "parameters": {
                "promptType": "define",
                "text": "={{ $('Webhook (WhatsApp)').item.json.body.data.message.conversation || $('Webhook (WhatsApp)').item.json.body.data.message.extendedTextMessage.text }}",
                "options": {
                    "systemMessage": "You are Yasmine, a helpful AI assistant for G777."
                }
            },
            "type": "@n8n/n8n-nodes-langchain.agent",
            "typeVersion": 1.7,
            "position": [
                -340,
