    {
      "parameters": {
        "jsCode": "// 1. Fetch memories — the input is the response from GET /memory\nconst inputData = $input.all()[0]?.json;\nlet memories = [];\nif (Array.isArray(inputData)) {\n    memories = inputData;\n} else if (inputData && Array.isArray(inputData.data)) {\n    memories = inputData.data;\n}\n\n// 2. Build Memory Text\nlet memoryText = 'No previous memory.';\nif (memories.length > 0 && memories[0].phone) {\n    memoryText = memories.map(m => `- ${m.fact || m.intent} (${m.created_at})`).join('\\n');\n}\n\n// 3. RECOVER ORIGINAL DATA — try each media branch in order\nlet originalData = {};\nconst nodesToTry = ['Transcribe a recording', 'Analyze Video1', 'Analyze an image1', 'Switch1', 'Webhook1'];\nfor (const nodeName of nodesToTry) {\n    try {\n        const item = $(nodeName).item;\n        if (item && Object.keys(item.json).length > 0) {\n            originalData = item.json;\n            break;\n        }\n    } catch (e) {\n        // Node not executed in this branch — try next\n    }\n}\n\nreturn {\n    json: {\n        ...originalData,\n        memoryContext: memoryText\n    }\n};"
      },
      "id": "e436e7a0-cac2-41ed-b908-901f7d443bce",
      "name": "Format Context (Addon)1",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3344,
        1280
      ]
    },
    {
      "parameters": {
        "jsCode": "// Use .first() and .last() to avoid Loop issues\nconst aiReply = $('AI Agent1').last().json.output || '';\n\nconst contextData = $('Format Context (Addon)1').first().json;\n\n// Extract phone — strip @s.whatsapp.net suffix if present\nconst phone = contextData.phone\n    || contextData.body?.data?.key?.remoteJid?.replace('@s.whatsapp.net', '')\n    || contextData.key?.remoteJid?.replace('@s.whatsapp.net', '')\n    || 'Unknown';\n\n// Extract user message — handle text, audio transcription, image and video analysis\nlet rawContent =\n    contextData.body?.data?.message?.conversation\n    || contextData.message?.conversation\n    || contextData.content\n    || contextData.text\n    || null;\n\n// For audio/video/image, the content is in the analysis node output embedded in contextData\nif (!rawContent) {\n    rawContent = '[Media Message]';\n}\nconst userMessage = String(rawContent);\n\n// Determine intent\nlet intent = 'general';\nif (userMessage.includes('?')) intent = 'question';\nif (String(aiReply).includes('?')) intent = 'ongoing';\n\nreturn {\n    json: {\n        phone,\n        intent,\n        fact: `User: \"${userMessage}\". AI: \"${aiReply}\"`\n    }\n};"
      },
