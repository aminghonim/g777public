      "id": "4390d7b2-9e34-41fb-b578-f5aa8e0ea06b",
      "name": "Get Memory (Addon)1",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        3152,
        1280
      ],
      "alwaysOutputData": true
