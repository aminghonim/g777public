    {
      "parameters": {
        "jsCode": "// \u0627\u0633\u062a\u062e\u062f\u0645\u0646\u0627 .first() \u0648 .last() \u0644\u062d\u0644 \u0645\u0634\u0643\u0644\u0629 \u0627\u0644\u0640 Loop\n// \ud83d\uded1 \u0625\u0636\u0627\u0641\u0629 (|| '') \u0644\u062a\u062c\u0646\u0628 \u0627\u0644\u062e\u0637\u0623 \u0644\u0648 \u0627\u0644\u0631\u062f \u0641\u0627\u0631\u063a\nconst aiReply = $('AI Agent').last().json.output || ''; \n\n// \u0646\u062d\u0627\u0648\u0644 \u0646\u062c\u064a\u0628 \u0627\u0644\u062f\u0627\u062a\u0627 \u0645\u0646 \u0623\u0642\u0631\u0628 \u0646\u0642\u0637\u0629 (Format Context)\nconst contextData = $('Format Context (Addon)').first().json;\n\n// \u0627\u0633\u062a\u062e\u0631\u0627\u062c \u0627\u0644\u0628\u064a\u0627\u0646\u0627\u062a \u0628\u0623\u0645\u0627\u0646\nconst phone = contextData.phone || contextData.key?.remoteJid?.replace('@s.whatsapp.net', '') || 'Unknown';\n\n// \ud83d\uded1 FIX: \u0627\u0644\u062a\u0623\u0643\u062f \u0623\u0646 \u0627\u0644\u0631\u0633\u0627\u0644\u0629 \u0646\u0635 \u062f\u0627\u0626\u0645\u0627\u064b (Force String)\n// \u0623\u062d\u064a\u0627\u0646\u0627\u064b conversation \u0644\u0627 \u062a\u0643\u0648\u0646 \u0645\u0648\u062c\u0648\u062f\u0629 \u0641\u064a \u0631\u0633\u0627\u0626\u0644 \u0627\u0644\u0645\u064a\u062f\u064a\u0627\u060c \u0623\u0648 \u062a\u0643\u0648\u0646 object\nlet rawContent = contextData.message?.conversation || contextData.content || contextData.text || 'Media Message';\nconst userMessage = String(rawContent); \n\n// \u062a\u062d\u062f\u064a\u062f \u0627\u0644\u0646\u064a\u0629 (Intent)\nlet intent = 'general';\n\n// \u0627\u0644\u0622\u0646 \u0646\u0636\u0645\u0646 \u0623\u0646 includes \u0633\u062a\u0639\u0645\u0644 \u0644\u0623\u0646\u0646\u0627 \u062d\u0648\u0644\u0646\u0627 \u0627\u0644\u0645\u062a\u063a\u064a\u0631 \u0644\u0646\u0635\nif (userMessage.includes('?')) intent = 'question';\nif (String(aiReply).includes('?')) intent = 'ongoing';\n\nreturn {\n    json: {\n        phone,\n        intent,\n        fact: `User: \"${userMessage}\". AI: \"${aiReply}\"`\n    }\n};"
      },
