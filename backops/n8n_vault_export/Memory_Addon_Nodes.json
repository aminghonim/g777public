    {
      "parameters": {
        "jsCode": "const memories = $input.all().map(i => i.json);\n\n// 1. Build Memory Text\nlet memoryText = 'No previous memory.';\nif (memories.length > 0 && memories[0].phone) {\n    memoryText = memories.map(m => `- ${m.fact || m.intent} (${m.created_at})`).join('\\n');\n}\n\n// 2. RECOVER ORIGINAL DATA (Crucial to keep workflow running)\nlet originalData = {};\n\ntry {\n    // Try fetching from Transcribe node if it ran\n    const audioItem = $('Transcribe a recording2').item;\n    if (audioItem) originalData = audioItem.json;\n} catch (e) {}\n\n// If no audio data, fall back to Webhook/Switch data\nif (Object.keys(originalData).length === 0) {\n    try {\n         // We try to get the item that entered the 'Switch' node\n         originalData = $('Switch').item.json;\n    } catch(e) {\n         originalData = $('Webhook').item.json;\n    }\n}\n\nreturn {\n    json: {\n        ...originalData, // Spread original data so AI Agent doesn't break\n        memoryContext: memoryText\n    }\n};"
      },
