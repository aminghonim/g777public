{
  "version": 2,
  "name": "g777-frontend",
  "builds": [
    {
      "src": "frontend_flutter/build/web/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "http://127.0.0.1:8000/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
