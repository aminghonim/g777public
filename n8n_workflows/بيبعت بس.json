      "parameters": {
        "jsCode": "const errorData = $input.first().json;\n// Get phone from the initial parser to be safe\nconst phone = $('2. Message Parser').first().json.phone || 'Unknown';\n\nlet errorType = 'UNKNOWN';\nlet errorMessage = 'Unknown error';\nlet statusCode = errorData.statusCode || 0;\n\n// Try to extract useful error message\nif (typeof errorData.error === 'object') {\n    if (errorData.error.message) errorMessage = errorData.error.message;\n    if (errorData.error.status) statusCode = errorData.error.status;\n} else if (errorData.message) {\n    errorMessage = errorData.message;\n}\n\nif (statusCode === 404) {\n  errorType = 'INSTANCE_NOT_FOUND';\n  errorMessage = 'Evolution Instance Name incorrect';\n} else if (statusCode === 401) {\n  errorType = 'AUTH_FAILED';\n}\n\nreturn {\n  json: {\n    status: 'ERROR',\n    errorType: errorType,\n    errorMessage: errorMessage,\n    statusCode: statusCode,\n    phone: phone,\n    timestamp: new Date().toISOString()\n  }\n};"
      },
