        "jsCode": "// تعديل مهم: قراءة النص من json.text\nconst agentResponse = $input.first().json.text; \n\n// قراءة الذاكرة من العقدة باسمها الصحيح (بدون رقم 4)\nconst memoryData = $('4.Session Memory Manager').first().json;\n\n// تحديد النية (بسيط جداً)\nlet intent = 'inquiry';\nif (/حجز|بوكينج|تفاصيل الحجز|سعر/i.test(memoryData.currentMessage)) {\n  intent = 'booking';\n}\n\nreturn {\n  json: {\n    phone: memoryData.phone,\n    aiResponse: agentResponse,\n    intent: intent,\n    newFact: `العميل سأل: ${memoryData.currentMessage.substring(0, 50)}...`, \n    timestamp: new Date().toISOString()\n  }\n};"
      },
