      "parameters": {
        "jsCode": "// جلب كل الذكريات اللي رجعت من Supabase\nconst memoryItems = $input.all().map(item => item.json);\n// جلب الرسالة الأصلية من العقدة الثانية\nconst parsedMessage = $('2. Message Parser').first().json;\n// تجميع الذكريات في نص واحد\nlet memoryContext = '';\nif (memoryItems.length > 0 && memoryItems[0].phone) {\n  memoryContext = memoryItems.map((m) => {\n    return `• ${m.fact || m.summary || m.intent || 'N/A'} (${m.create_at || ''})`;\n  }).join('\\n');\n} else {\n  memoryContext = 'لا توجد سجلات سابقة لهذا العميل.';\n}\n// تجهيز \"الطبق النهائي\" للذكاء الاصطناعي\nconst sessionContext = {\n  phone: parsedMessage.phone,\n  customerName: parsedMessage.customerName,\n  currentMessage: parsedMessage.message,\n  intent: parsedMessage.intent,\n  timestamp: parsedMessage.timestamp,\n  memoryContext: memoryContext, // هنا تاريخ العميل كله\n  sessionId: `session_${parsedMessage.phone}_${Date.now()}`\n};\nreturn { json: sessionContext };"
      },
