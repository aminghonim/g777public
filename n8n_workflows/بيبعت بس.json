      "parameters": {
        "jsCode": "/* Fixed Final Log Node (Smart Reference) */\n\n// 1. Get Phone & Name (Guaranteed to exist from Message Parser)\nconst inputData = $('2. Message Parser').first().json;\n\n// 2. Get Agent Response (Try both name variations)\nlet responseText = \"No response\";\nlet intent = \"unknown\";\n\ntry {\n  // Try finding the node with Space\n  const processorNode = $('6. Response Processor').first().json; \n  responseText = processorNode.aiResponse;\n  intent = processorNode.intent;\n} catch(e1) {\n  try {\n     // Try finding the node WITHOUT Space\n     const processorNode2 = $('6.Response Processor').first().json;\n     responseText = processorNode2.aiResponse;\n     intent = processorNode2.intent;\n  } catch(e2) {\n     responseText = \"Address/Node not found\";\n  }\n}\n\n// 3. Construct Final Report\nconst log = {\n  status: 'SUCCESS',\n  timestamp: new Date().toISOString(),\n  phone: inputData.phone,\n  name: inputData.customerName,\n  intent: intent,\n  response_preview: responseText ? responseText.substring(0, 50) + \"...\" : \"Empty\", \n  sent: true\n};\n\nreturn { json: log };"
      },
