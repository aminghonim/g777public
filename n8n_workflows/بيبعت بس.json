        "jsCode": "const incoming = $input.first().json;\n\n// ده السطر السحري اللي بيجيب البيانات من جوه الصندوق المقفول\nconst data = incoming.body?.data || incoming.body || incoming;\nconst key = data.key || data;\n\n// هنا بنطلع رقم التليفون وننظفه من أي زيادات\nlet phone = (key.remoteJid || key.from || '').replace('@c.us', '').replace('@s.whatsapp.net', '');\n\n// وهنا بنجيب نص الرسالة\nconst messageContent = data.message || {};\nconst messageText = messageContent.conversation || messageContent.extendedTextMessage?.text || data.body || '';\n\nreturn { \n  json: { \n    phone: phone, \n    message: messageText, \n    customerName: data.pushName || 'عميل' \n  } \n};"
