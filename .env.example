# ═══════════════════════════════════════════════════════════════════
# G777 Environment Template
# ═══════════════════════════════════════════════════════════════════

# Core DB (Supabase)
DATABASE_URL=postgresql://user:pass@host:6543/postgres
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ==============================================================================
# NETWORK SECURITY (Internal Service Authentication)
# Do NOT commit real values. All containers read these from Docker environment.
# ==============================================================================
G777_HANDSHAKE_TOKEN=change_me_before_production
BRIDGE_API_KEY=change_me_before_production

# Evolution API (Baileys Bridge)
EVOLUTION_PUBLIC_URL=http://localhost:8080
EVOLUTION_API_KEY=your_evolution_key
EVOLUTION_INSTANCE_NAME=G777
BAILEYS_API_URL=http://localhost:3000

# AI Models
GEMINI_API_KEY=your_gemini_key
DEEPSEEK_API_KEY=your_deepseek_key


# ==============================================================================
# MODERN FREE STACK INTEGRATIONS
# ==============================================================================

# Resend (Emails) - Free 3,000/mo
RESEND_API_KEY=re_your_api_key

# Pinecone (Vector DB) - Free 1 index
PINECONE_API_KEY=your_pinecone_key
PINECONE_ENVIRONMENT=us-east-1-gcp
PINECONE_INDEX_NAME=g777-memory

# Upstash Redis (Caching/Rate Limits) - Free 10k req/day
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# GlitchTip / Sentry (Error Tracking) - Free open source
SENTRY_DSN=https://your_dsn@sentry.io/project_id

# PostHog (Analytics) - Free 1M events/month
# Backend: POSTHOG_API_KEY, Frontend dart-define: POSTHOG_API_KEY
POSTHOG_API_KEY=phc_your_posthog_key
POSTHOG_HOST=https://app.posthog.com

# Clerk (Authentication)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key

# n8n Settings (must match docker-compose ENCRYPTION_KEY)
N8N_ENCRYPTION_KEY=generate_a_random_32_char_string_here

# GitHub Pages / Deployment
API_BASE_URL=https://your-backend-url.com

