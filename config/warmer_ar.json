[
    "إيه الأخبار يا صاحبي؟",
    "عامل إيه النهاردة؟",
    "فينك يابني مختفي ليه؟",
    "بقولك إيه فاضي بكرة؟",
    "يا مسهل يارب",
    "صباح الفل يا غالي",
    "الجو عامل إيه عندكم؟",
    "طمني عليك يا ريس",
    "إيه الدنيا؟",
    "عاش يا بطل",
    "متنساش ميعادنا وبس",
    "بالتوفيق دايماً يا رب",
    "يا هلا يا هلا",
    "أيوة كده يا سيدي",
    "كلام جميل ومحترم",
    "ربنا يكرمك ويوفقك",
    "تسلم إيدك يا محترم",
    "ألف شكر يا غالي",
    "حبيبي تسلم",
    "بالظبط كده زي ما قولتلك",
    "هنظبط الدنيا إن شاء الله",
    "خلينا على تواصل",
    "مستني ردك يا كبير",
    "معاك حق طبعاً",
    "الحمد لله على كل حال"
]
