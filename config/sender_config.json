{
    "whatsapp": {
        "headless": false,
        "user_data_dir": "./chrome_profile"
    },
    "delays": {
        "min_seconds": 10,
        "max_seconds": 20,
        "after_send": 3,
        "page_load": 5
    },
    "messages": {
        "default_text": "مرحباً {name}! 👋",
        "templates": [
            "مرحباً {name}! 👋 كيف يمكنني مساعدتك؟",
            "أهلاً {name}! 🌟 لدينا عروض مميزة لك",
            "السلام عليكم {name}! ✨ تواصل معنا للمزيد"
        ]
    },
    "automation": {
        "total_images": 100,
        "start_from_row": 0
    },
    "safety": {
        "max_messages_per_hour": 30,
        "max_messages_per_day": 200,
        "pause_after_errors": 3
    }
}
